#!/usr/bin/env bash
set -u

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/launchpad-route.log"
mkdir -p "$LOG_DIR"

exec > >(tee -a "$LOG_FILE") 2>&1

APPLY=0
if [ "${1:-}" = "--apply" ]; then
  APPLY=1
elif [ "${1:-}" != "" ]; then
  printf 'Usage: %s [--apply]\n' "$0"
  exit 2
fi

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

find_port() {
  local client_pattern="$1"
  local port_pattern="$2"
  local client_id=""
  local in_client=0

  while IFS= read -r line; do
    case "$line" in
      client\ * )
        in_client=0
        if printf '%s\n' "$line" | grep -Ei "$client_pattern" >/dev/null 2>&1; then
          client_id="$(printf '%s\n' "$line" | sed -n "s/^client \([0-9][0-9]*\):.*/\1/p")"
          in_client=1
        fi
        ;;
      * )
        if [ "$in_client" -eq 1 ] && printf '%s\n' "$line" | grep -Ei "$port_pattern" >/dev/null 2>&1; then
          local port_id
          port_id="$(printf '%s\n' "$line" | sed -n "s/^[[:space:]]*\([0-9][0-9]*\)[[:space:]].*/\1/p")"
          if [ "$client_id" != "" ] && [ "$port_id" != "" ]; then
            printf '%s:%s\n' "$client_id" "$port_id"
            return 0
          fi
        fi
        ;;
    esac
  done

  return 1
}

connect_route() {
  local src_label="$1"
  local src="$2"
  local dst_label="$3"
  local dst="$4"

  printf '%s -> %s\n' "$src_label ($src)" "$dst_label ($dst)"
  if [ "$APPLY" -eq 1 ]; then
    aconnect "$src" "$dst" || printf 'WARN: failed to connect %s -> %s, exit code %s\n' "$src" "$dst" "$?"
  fi
}

printf '[%s] Launchpad temporary route start\n' "$(date '+%Y-%m-%d %H:%M:%S')"
printf 'WINEPREFIX=%s\n' "$WINEPREFIX"

if ! has_cmd aconnect; then
  printf 'ERROR: aconnect not found\n'
  exit 1
fi

aconnect_output="$(aconnect -l 2>&1)"

launchpad_port="$(printf '%s\n' "$aconnect_output" | find_port 'Launchpad' 'Launchpad.*MIDI|MIDI')"
virmidi_port="$(printf '%s\n' "$aconnect_output" | find_port 'Virtual Raw MIDI 1-0|VirMIDI 1-0' 'VirMIDI 1-0')"
wine_port="$(printf '%s\n' "$aconnect_output" | find_port 'WINE midi driver' 'WINE ALSA Input')"

printf 'Launchpad S port: %s\n' "${launchpad_port:-NOT FOUND}"
printf 'VirMIDI 1-0 port: %s\n' "${virmidi_port:-NOT FOUND}"
printf 'WINE ALSA Input port: %s\n' "${wine_port:-NOT FOUND}"

if [ "${wine_port:-}" = "" ]; then
  printf 'ERROR: WINE ALSA Input not found. Start the DAW session first:\n'
  printf '  ./bin/disable-ableton-updates\n'
  printf '  pw-jack ./bin/session\n'
  printf '\n'
  printf 'Then run this helper from a second shell.\n'
  exit 1
fi

if [ "${launchpad_port:-}" = "" ] || [ "${virmidi_port:-}" = "" ]; then
  printf 'ERROR: required Launchpad/VirMIDI ports were not all found; no routes applied\n'
  exit 1
fi

if [ "$APPLY" -eq 1 ]; then
  printf '\nApplying temporary ALSA MIDI routes:\n'
else
  printf '\nDry run. These temporary ALSA MIDI routes would be applied with --apply:\n'
fi

connect_route "Launchpad S" "$launchpad_port" "WINE ALSA Input" "$wine_port"
connect_route "VirMIDI 1-0" "$virmidi_port" "WINE ALSA Input" "$wine_port"

printf '\nThese routes are not persistent. They disappear when disconnected, clients restart, or the system reboots.\n'
printf '[%s] Launchpad temporary route end\n' "$(date '+%Y-%m-%d %H:%M:%S')"
