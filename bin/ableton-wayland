#!/usr/bin/env bash
# Stable Ableton presentation path for a KDE Plasma Wayland session.
#
# Wine is intentionally kept on XWayland here. Native winewayland.drv does not
# yet negotiate xdg-decoration, so it cannot provide KDE's server-side frame.
# The Proton runner's sizing shim preserves Ableton's File/Edit menu row and
# its runtime KWin controller pins the native KDE frame without persistent
# window rules. Use bin/ableton-native-wayland only for driver experiments.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  printf 'ERROR: bin/ableton-wayland requires a Wayland desktop session.\n' >&2
  exit 1
fi
if [[ -z "${DISPLAY:-}" ]]; then
  printf 'ERROR: DISPLAY is unset; the stabilized path requires XWayland.\n' >&2
  exit 1
fi

export WAYDAW_ABLETON_WINDOW_DRIVER=x11
exec "$ROOT_DIR/bin/ableton-proton" "$@"
