#!/usr/bin/env bash
set -euo pipefail

# Wayland-driver windowing test launcher.
#
# Launches Ableton Live 12 with Wine's native Wayland driver by unsetting
# DISPLAY for the wine process only. Wine >= 10 selects the Wayland driver
# automatically when DISPLAY is absent and WAYLAND_DISPLAY is present.
#
# Why this path matters: the managed-window flicker is an XWayland frame
# synchronization defect in KWin 5.27 (fixed upstream in Plasma 6.2/6.3).
# The native Wayland driver bypasses XWayland entirely, so KWin treats
# Ableton as a normal Wayland client: real stacking, real close behavior,
# no XWayland sync involvement. See docs/ROOT_CAUSE_AND_FIX_PLAN.md.
#
# This script mutates nothing: no registry changes, no harness changes.
# It is a user-run windowing test, not part of the stable session workflow.
# Recover from a stuck state with ./bin/kill-session.

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/ableton-wayland.log"
mkdir -p "$LOG_DIR"

warn_if_ableton_updates_present() {
  local autoupdates="$WINEPREFIX/drive_c/ProgramData/Ableton/Live 12 Suite/_autoupdates"
  local updated="$WINEPREFIX/drive_c/ProgramData/Ableton/.Live 12 Suite_updated"
  local found=0

  if [[ -e "$autoupdates" ]]; then
    printf 'WARNING: Ableton auto-update directory is present: %s\n' "$autoupdates"
    found=1
  fi

  if [[ -e "$updated" ]]; then
    printf 'WARNING: Ableton updater swap marker is present: %s\n' "$updated"
    found=1
  fi

  if [[ "$found" -eq 1 ]]; then
    printf 'WARNING: Ableton auto-updater state is unstable under Wine and may cause sharing violations or updater loops.\n'
    printf 'WARNING: Run ./bin/disable-ableton-updates before launching the DAW session.\n'
  fi
}

find_ableton_exe() {
  local drive_c="$WINEPREFIX/drive_c"
  local candidate

  for candidate in \
    "$drive_c/ProgramData/Ableton/Live 12 Suite/Program/Ableton Live 12 Suite.exe" \
    "$drive_c/ProgramData/Ableton/Live 12 Standard/Program/Ableton Live 12 Standard.exe" \
    "$drive_c/ProgramData/Ableton/Live 12 Intro/Program/Ableton Live 12 Intro.exe" \
    "$drive_c/Program Files/Ableton/Live 12 Suite/Program/Ableton Live 12 Suite.exe" \
    "$drive_c/Program Files/Ableton/Live 12 Standard/Program/Ableton Live 12 Standard.exe" \
    "$drive_c/Program Files/Ableton/Live 12 Intro/Program/Ableton Live 12 Intro.exe" \
    "$drive_c/Program Files (x86)/Ableton/Live 12 Suite/Program/Ableton Live 12 Suite.exe" \
    "$drive_c/Program Files (x86)/Ableton/Live 12 Standard/Program/Ableton Live 12 Standard.exe" \
    "$drive_c/Program Files (x86)/Ableton/Live 12 Intro/Program/Ableton Live 12 Intro.exe"; do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  find "$drive_c" -type f -iname 'Ableton Live 12*.exe' 2>/dev/null | head -n 1
}

if ! command -v wine >/dev/null 2>&1; then
  printf 'ERROR: wine not found on PATH.\n' >&2
  exit 1
fi

if [[ ! -d "$WINEPREFIX" ]]; then
  printf 'ERROR: WINEPREFIX does not exist: %s\n' "$WINEPREFIX" >&2
  exit 1
fi

if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  printf 'ERROR: WAYLAND_DISPLAY is not set; the Wine Wayland driver needs a Wayland session.\n' >&2
  exit 1
fi

ableton_exe="$(find_ableton_exe)"
if [[ -z "$ableton_exe" ]]; then
  printf 'ERROR: Ableton Live 12 executable not found in %s\n' "$WINEPREFIX" >&2
  printf 'Expected an installed Live 12 executable under drive_c/ProgramData or drive_c/Program Files.\n' >&2
  exit 1
fi

# Optional verbose Wayland driver tracing: ./bin/ableton-wayland --debug-wayland
wine_debug="${WINEDEBUG:-}"
if [[ "${1:-}" == "--debug-wayland" ]]; then
  wine_debug="warn+waylanddrv,warn+vulkan,warn+wgl"
  shift
fi

warn_if_ableton_updates_present | tee -a "$LOG_FILE"

decorated_state="$(env -u DISPLAY wine reg query 'HKCU\Software\Wine\X11 Driver' /v Decorated 2>/dev/null | awk '/Decorated/ {print $3}')"
if [[ "${decorated_state:-Y}" != "Y" ]]; then
  printf 'WARNING: Wine registry Decorated=%s; the previous Wayland test may have run undecorated for this reason.\n' "$decorated_state" | tee -a "$LOG_FILE"
fi

printf '[%s] launching Ableton via Wine Wayland driver: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$ableton_exe" >>"$LOG_FILE"
{
  printf '[%s] effective environment before Wayland-driver Ableton launch\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  printf 'WINEPREFIX=%s\n' "$WINEPREFIX"
  printf 'DISPLAY=(unset for wine process; host value was %s)\n' "${DISPLAY:-empty}"
  printf 'WAYLAND_DISPLAY=%s\n' "${WAYLAND_DISPLAY:-}"
  printf 'WINEDEBUG=%s\n' "${wine_debug:-default}"
  printf 'Decorated=%s\n' "${decorated_state:-unknown}"
  printf 'Ableton executable=%s\n' "$ableton_exe"
} | tee -a "$LOG_FILE"

wine_env=(env -u DISPLAY)
if [[ -n "$wine_debug" ]]; then
  wine_env+=(WINEDEBUG="$wine_debug")
fi

set +e
"${wine_env[@]}" wine "$ableton_exe" "$@" 2>&1 | tee -a "$LOG_FILE"
wine_status="${PIPESTATUS[0]}"
set -e

printf '[%s] Ableton (Wayland driver) wine exit code: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$wine_status" | tee -a "$LOG_FILE"
exit "$wine_status"
