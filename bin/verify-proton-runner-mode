#!/usr/bin/env bash
# Dry-run verification suite for the opt-in Proton-exp runner mode.
# Launches NOTHING. Never touches the working prefix (reads its DXVK DLLs
# read-only as the reassert source). Exits nonzero if any check fails.
set -uo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PASS=0; FAIL=0
ok()   { printf '  PASS: %s\n' "$1"; PASS=$((PASS+1)); }
bad()  { printf '  FAIL: %s\n' "$1"; FAIL=$((FAIL+1)); }
check(){ local desc="$1" hay="$2" needle="$3"; [[ "$hay" == *"$needle"* ]] && ok "$desc" || bad "$desc (missing: $needle)"; }
ncheck(){ local desc="$1" hay="$2" needle="$3"; [[ "$hay" != *"$needle"* ]] && ok "$desc" || bad "$desc (unexpected: $needle)"; }

WORKING_PREFIX="$HOME/WinePrefixes/ableton12"
PROTON_PREFIX="$HOME/WinePrefixes/ableton12-winebase-protonexp-test"
RUNNER_WINE="$ROOT_DIR/.local-runners/kron4ek-proton-exp-11.0/bin/wine"
DXVK_D3D11_SHA=557c1f50e7ff73bcd24968a02352519df89d8b3fe037d47580091ffafe1940dd
DXVK_DXGI_SHA=f31cd64b547c59441956b17e2a013791dcb62abb1e671fb31d49ff4d6c2b3fd7

printf '== 1. default runner resolution (system Wine, working prefix) ==\n'
out="$(WAYDAW_ABLETON_GRAPHICS=dxvk WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
err="$(WAYDAW_ABLETON_GRAPHICS=dxvk WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>&1 >/dev/null)"
check "default wine is /usr/bin/wine"        "$out" "wine_binary=/usr/bin/wine"
check "default prefix is working prefix"     "$out" "wineprefix=$WORKING_PREFIX"
check "default keeps registry mutation"      "$out" "registry_mutation_enabled=yes"
check "default has no kwin controller"       "$out" "kwin_decoration_controller=no"
ncheck "default prints no runner line"       "$err" "WAYDAW runner="

printf '== 2. proton-exp runner resolution (copied prefix) ==\n'
out="$(WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
err="$(WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>&1 >/dev/null)"
check "proton wine is the runner binary"     "$out" "wine_binary=$RUNNER_WINE"
check "proton prefix is the copied prefix"   "$out" "wineprefix=$PROTON_PREFIX"
check "proton keeps DXVK (graphics=dxvk)"    "$out" "graphics_mode=dxvk"
check "proton overrides only the shim dll"   "$out" "winedlloverrides=version=n,b"
check "proton disables registry mutation"    "$out" "registry_mutation_enabled=no"
check "proton uses no virtual desktop"       "$out" "virtual_desktop_mutation_enabled=no"
check "proton preserves -u WAYLAND_DISPLAY"  "$out" "env -u WAYLAND_DISPLAY"
check "proton sets shim override on cmd"     "$out" "WINEDLLOVERRIDES=version"
out_noshim="$(WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_SIZING_SHIM=0 WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
check "shim opt-out restores -u WINEDLLOVERRIDES" "$out_noshim" "-u WINEDLLOVERRIDES"
check "proton logs runner resolution"        "$err" "WAYDAW runner=proton-exp"
check "proton plans kwin controller load"    "$out" "kwin_decoration_controller=would_load"
out_optout="$(WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_KWIN_CONTROLLER=0 WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
check "controller opt-out respected"         "$out_optout" "kwin_decoration_controller=no"

printf '== 3. unknown runner rejected ==\n'
err="$(WAYDAW_ABLETON_RUNNER=bogus WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>&1 >/dev/null)"
check "unknown runner is rejected"           "$err" "unknown WAYDAW_ABLETON_RUNNER=bogus"

printf '== 4. proton-exp refuses the working prefix ==\n'
err="$(WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_RUNNER_PREFIX="$WORKING_PREFIX" WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>&1 >/dev/null)"
check "refuses working prefix"               "$err" "refuses to target the working prefix"

printf '== 5. DXVK reassertion (test DLLs only; working prefix read-only) ==\n'
wp_before="$(sha256sum "$WORKING_PREFIX/drive_c/windows/system32/d3d11.dll" | awk '{print $1}')"
SCRATCH="$(mktemp -d)"; SSYS="$SCRATCH/drive_c/windows/system32"; mkdir -p "$SSYS"
printf 'not-dxvk-drifted' > "$SSYS/d3d11.dll"                 # drifted -> should be restored
cp "$WORKING_PREFIX/drive_c/windows/system32/dxgi.dll" "$SSYS/dxgi.dll"  # already correct
WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_RUNNER_PREFIX="$SCRATCH" \
  bash -c 'source config/env >/dev/null 2>&1' 2>/dev/null
d3d11_after="$(sha256sum "$SSYS/d3d11.dll" | awk '{print $1}')"
dxgi_after="$(sha256sum "$SSYS/dxgi.dll" | awk '{print $1}')"
wp_after="$(sha256sum "$WORKING_PREFIX/drive_c/windows/system32/d3d11.dll" | awk '{print $1}')"
[[ "$d3d11_after" == "$DXVK_D3D11_SHA" ]] && ok "drifted d3d11 restored to debug DXVK" || bad "drifted d3d11 NOT restored ($d3d11_after)"
[[ "$dxgi_after" == "$DXVK_DXGI_SHA" ]] && ok "correct dxgi left intact" || bad "dxgi changed unexpectedly"
[[ "$wp_after" == "$wp_before" ]] && ok "working prefix DXVK untouched by reassert" || bad "working prefix DXVK CHANGED"
rm -rf "$SCRATCH"

printf '== 6. cleanup scope (targets copied prefix + runner wineserver, not working) ==\n'
out="$(./bin/ableton-proton-cleanup --dry-run 2>&1)"
check "cleanup targets the copied prefix"     "$out" "target_proton_prefix=$PROTON_PREFIX"
check "cleanup uses the runner wineserver"    "$out" "kron4ek-proton-exp-11.0/bin/wineserver"
ncheck "cleanup does not kill working prefix"  "$out" "pkill -KILL -f \"$WORKING_PREFIX\""
outw="$(WAYDAW_ABLETON_RUNNER_PREFIX="$WORKING_PREFIX" ./bin/ableton-proton-cleanup --dry-run 2>&1 || true)"
check "cleanup refuses working prefix"         "$outw" "refusing to clean the working prefix"
check "cleanup would unload kwin controller"   "$out" "ableton-kwin-decoration-controller --unload"

printf '== 7. kwin decoration controller lifecycle (runtime scripting; no KWin settings) ==\n'
CTL=./bin/ableton-kwin-decoration-controller
if [[ "$("$CTL" --status 2>/dev/null)" == *loaded=* ]]; then
  "$CTL" --unload >/dev/null 2>&1   # normalize: suite starts from unloaded
  # Ableton dry-run must not load the controller.
  WAYDAW_ABLETON_RUNNER=proton-exp WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton >/dev/null 2>&1
  st="$("$CTL" --status)"
  check "ableton dry-run does not load controller" "$st" "loaded=false"
  out="$("$CTL" --load 2>&1)"; st="$("$CTL" --status)"
  check "explicit load succeeds"                "$out" "loaded: waydaw-ableton-decoration"
  check "status reports loaded"                 "$st"  "loaded=true"
  out2="$("$CTL" --load 2>&1)"
  check "second load is idempotent"             "$out2" "already loaded"
  # Real cleanup run: safe with no session (kill commands match nothing) and
  # must unload the controller.
  outc="$(./bin/ableton-proton-cleanup 2>&1)"; st="$("$CTL" --status)"
  check "cleanup unloads controller"            "$outc" "kwin_controller_unload=ok"
  check "status reports unloaded after cleanup" "$st"  "loaded=false"
  out="$("$CTL" --unload 2>&1)"
  check "unload when not loaded is safe"        "$out" "nothing to unload"
else
  bad "controller --status unavailable (KWin scripting not reachable?)"
fi

printf '== 8. bin/ableton-proton explicit launcher (dry-run only) ==\n'
SU_CFG="$(ls "$PROTON_PREFIX"/drive_c/users/steamuser/AppData/Roaming/Ableton/Live\ */Preferences/Preferences.cfg 2>/dev/null | head -1)"
cfg_before=""; [[ -n "$SU_CFG" ]] && cfg_before="$(sha256sum "$SU_CFG" | awk '{print $1}')"
out="$(WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>/dev/null)"
err="$(WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>&1 >/dev/null)"
check "launcher resolves to proton-exp runner"   "$err" "WAYDAW runner=proton-exp"
check "launcher uses the runner wine binary"     "$out" "wine_binary=$RUNNER_WINE"
check "launcher uses the copied prefix"          "$out" "wineprefix=$PROTON_PREFIX"
check "launcher disables registry mutation"      "$out" "registry_mutation_enabled=no"
check "launcher uses no virtual desktop"         "$out" "virtual_desktop_mutation_enabled=no"
check "launcher plans kwin controller load"      "$out" "kwin_decoration_controller=would_load"
check "launcher dry-run reports clamp intent"    "$err" "would clamp MainWindow placement height"
out_optout="$(WAYDAW_ABLETON_KWIN_CONTROLLER=0 WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>/dev/null)"
check "launcher controller opt-out respected"    "$out_optout" "kwin_decoration_controller=no"
if [[ -n "$SU_CFG" ]]; then
  cfg_after="$(sha256sum "$SU_CFG" | awk '{print $1}')"
  [[ "$cfg_after" == "$cfg_before" ]] && ok "launcher dry-run does not mutate steamuser Preferences.cfg" \
    || bad "launcher dry-run MUTATED steamuser Preferences.cfg"
else
  ok "no steamuser Preferences.cfg present (mutation check vacuous)"
fi
st="$(./bin/ableton-kwin-decoration-controller --status)"
check "launcher dry-run does not load controller" "$st" "loaded=false"
out="$(WAYDAW_ABLETON_GRAPHICS=dxvk WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
check "plain bin/ableton still defaults to system wine" "$out" "wine_binary=/usr/bin/wine"
check "plain bin/ableton still uses working prefix"     "$out" "wineprefix=$WORKING_PREFIX"

printf '== 9. sizing shim (dry-run only; no prefix mutation) ==\n'
SHIM_DLL="$ROOT_DIR/.local-tools/ableton-sizing-shim/version.dll"
SHIM_TARGET="$PROTON_PREFIX/drive_c/ProgramData/Ableton/Live 12 Suite/Program/version.dll"
if [[ -f "$SHIM_DLL" ]]; then
  [[ "$(head -c2 "$SHIM_DLL")" == "MZ" ]] && ok "shim DLL artifact is a PE binary" || bad "shim DLL artifact is not a PE binary"
else
  bad "shim DLL not built ($SHIM_DLL); run compat/ableton-sizing-shim/build.sh"
fi
target_before="none"; [[ -f "$SHIM_TARGET" ]] && target_before="$(sha256sum "$SHIM_TARGET" | awk '{print $1}')"
out="$(WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>/dev/null)"
check "dry-run discloses shim enablement"     "$out" "sizing_shim=would_enable"
check "dry-run discloses shim source dll"     "$out" "sizing_shim_dll=$SHIM_DLL"
check "dry-run discloses shim install target" "$out" "sizing_shim_target=$SHIM_TARGET"
check "dry-run discloses shim cap height"     "$out" "sizing_shim_cap_h=1040"
out_capoverride="$(WAYDAW_ABLETON_SIZING_CAP_H=1024 WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>/dev/null)"
check "shim cap height is overridable"        "$out_capoverride" "sizing_shim_cap_h=1024"
check "dry-run command carries shim override" "$out" "WINEDLLOVERRIDES=version"
target_after="none"; [[ -f "$SHIM_TARGET" ]] && target_after="$(sha256sum "$SHIM_TARGET" | awk '{print $1}')"
[[ "$target_after" == "$target_before" ]] && ok "dry-run does not install/modify the shim in the prefix" \
  || bad "dry-run MUTATED the shim target in the prefix"
out_noshim="$(WAYDAW_ABLETON_SIZING_SHIM=0 WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton-proton 2>/dev/null)"
check "shim opt-out respected by launcher"    "$out_noshim" "sizing_shim=no"
out_default="$(WAYDAW_ABLETON_GRAPHICS=dxvk WAYDAW_ABLETON_DRY_RUN=1 ./bin/ableton 2>/dev/null)"
check "default launcher has no sizing shim"   "$out_default" "sizing_shim=no"
ncheck "default launcher has no shim override" "$out_default" "version=n,b"
[[ -f "$WORKING_PREFIX/drive_c/ProgramData/Ableton/Live 12 Suite/Program/version.dll" ]] \
  && bad "working prefix contains a version.dll shim (must never happen)" \
  || ok "working prefix has no shim DLL"

printf '\n== summary ==\npass=%s fail=%s\n' "$PASS" "$FAIL"
[[ "$FAIL" -eq 0 ]]
