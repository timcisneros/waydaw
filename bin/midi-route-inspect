#!/usr/bin/env bash
set -u

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/midi-route.log"
mkdir -p "$LOG_DIR"

exec > >(tee -a "$LOG_FILE") 2>&1

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

section() {
  printf '\n== %s ==\n' "$1"
}

run_aconnect() {
  local label="$1"
  shift

  section "$label"
  if has_cmd aconnect; then
    aconnect "$@" || printf 'WARN: aconnect %s exited with code %s\n' "$*" "$?"
  else
    printf 'WARN: aconnect not found\n'
  fi
}

highlight_clients() {
  local label="$1"
  local pattern="$2"
  local data="$3"

  section "$label"
  if printf '%s\n' "$data" | grep -Ei "$pattern" >/dev/null 2>&1; then
    printf '%s\n' "$data" | grep -Ei -A 6 "$pattern" || true
  else
    printf 'NOT FOUND: %s\n' "$label"
  fi
}

printf '[%s] MIDI route inspect start\n' "$(date '+%Y-%m-%d %H:%M:%S')"
printf 'WINEPREFIX=%s\n' "$WINEPREFIX"

aconnect_l=""
aconnect_i=""
aconnect_o=""

if has_cmd aconnect; then
  section "aconnect -l"
  aconnect_l="$(aconnect -l 2>&1)"
  printf '%s\n' "$aconnect_l"

  section "aconnect -i"
  aconnect_i="$(aconnect -i 2>&1)"
  printf '%s\n' "$aconnect_i"

  section "aconnect -o"
  aconnect_o="$(aconnect -o 2>&1)"
  printf '%s\n' "$aconnect_o"
else
  section "aconnect"
  printf 'WARN: aconnect not found\n'
fi

section "Currently connected MIDI routes"
if printf '%s\n' "$aconnect_l" | grep -E 'Connecting To:|Connected From:' >/dev/null 2>&1; then
  printf '%s\n' "$aconnect_l" | grep -E 'client |    [0-9]+ |Connecting To:|Connected From:' || true
else
  printf 'No active ALSA MIDI routes reported by aconnect -l.\n'
fi

combined_output="$(printf '%s\n%s\n%s\n' "$aconnect_l" "$aconnect_i" "$aconnect_o")"
highlight_clients "VirMIDI clients" 'VirMIDI|Virtual Raw MIDI|Virtual MIDI' "$combined_output"
highlight_clients "WINE midi driver clients" 'WINE midi driver|WINE ALSA' "$combined_output"

printf '\n[%s] MIDI route inspect end\n' "$(date '+%Y-%m-%d %H:%M:%S')"
