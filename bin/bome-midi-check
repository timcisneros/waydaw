#!/usr/bin/env bash
set -u

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/bome-midi-check.log"
mkdir -p "$LOG_DIR"

exec > >(tee -a "$LOG_FILE") 2>&1

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

section() {
  printf '\n== %s ==\n' "$1"
}

run_or_warn() {
  local label="$1"
  shift

  section "$label"
  if has_cmd "$1"; then
    "$@" || printf 'WARN: %s exited with code %s\n' "$*" "$?"
  else
    printf 'WARN: %s not found\n' "$1"
  fi
}

print_process_state() {
  local label="$1"
  local pattern="$2"

  if pgrep -af "$pattern" >/dev/null 2>&1; then
    printf 'RUNNING: %s\n' "$label"
    pgrep -af "$pattern" || true
  else
    printf 'NOT RUNNING: %s\n' "$label"
  fi
}

detect_ports() {
  local label="$1"
  local pattern="$2"
  local data="$3"

  if printf '%s\n' "$data" | grep -Ei "$pattern" >/dev/null 2>&1; then
    printf 'VISIBLE: %s\n' "$label"
    printf '%s\n' "$data" | grep -Ei "$pattern" || true
  else
    printf 'NOT VISIBLE: %s\n' "$label"
  fi
}

printf '[%s] Bome MIDI check start\n' "$(date '+%Y-%m-%d %H:%M:%S')"
printf 'WINEPREFIX=%s\n' "$WINEPREFIX"

section "Process status"
print_process_state "Bome MIDI Translator Pro" 'Bome|MIDITranslator'
print_process_state "Ableton Live" 'Ableton Live 12|Ableton Live 12 Suite.exe'

alsa_output=""
pipewire_output=""
jack_ports_output=""
jack_connections_output=""

section "ALSA MIDI ports: aconnect -l"
if has_cmd aconnect; then
  alsa_output="$(aconnect -l 2>&1)"
  printf '%s\n' "$alsa_output"
else
  printf 'WARN: aconnect not found\n'
fi

section "PipeWire links: pw-link -l"
if has_cmd pw-link; then
  pipewire_output="$(pw-link -l 2>&1)"
  printf '%s\n' "$pipewire_output"
else
  printf 'WARN: pw-link not found\n'
fi

section "JACK MIDI ports: pw-jack jack_lsp -A"
if has_cmd pw-jack && has_cmd jack_lsp; then
  jack_ports_output="$(pw-jack jack_lsp -A 2>&1)"
  printf '%s\n' "$jack_ports_output"
else
  printf 'WARN: pw-jack or jack_lsp not found\n'
fi

section "JACK MIDI connections: pw-jack jack_lsp -c"
if has_cmd pw-jack && has_cmd jack_lsp; then
  jack_connections_output="$(pw-jack jack_lsp -c 2>&1)"
  printf '%s\n' "$jack_connections_output"
else
  printf 'WARN: pw-jack or jack_lsp not found\n'
fi

combined_output="$(printf '%s\n%s\n%s\n%s\n' "$alsa_output" "$pipewire_output" "$jack_ports_output" "$jack_connections_output")"

section "Detected visible MIDI/graph names"
detect_ports "Launchpad" 'Launchpad' "$combined_output"
detect_ports "Novation" 'Novation' "$combined_output"
detect_ports "VirMIDI" 'VirMIDI|Virtual Raw MIDI|Virtual MIDI' "$combined_output"
detect_ports "WINE midi driver" 'WINE midi driver|WINE ALSA' "$combined_output"
detect_ports "Bome" 'Bome|BMIDI' "$combined_output"
detect_ports "MIDITranslator" 'MIDITranslator|MIDI Translator' "$combined_output"
detect_ports "Ableton" 'Ableton|Live 12' "$combined_output"
detect_ports "Midi Through" 'Midi Through' "$combined_output"
detect_ports "PipeWire" 'PipeWire|Midi-Bridge' "$combined_output"

printf '\n[%s] Bome MIDI check end\n' "$(date '+%Y-%m-%d %H:%M:%S')"
