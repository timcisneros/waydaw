#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

prefs_dir="$WINEPREFIX/drive_c/users/$USER/AppData/Roaming/Ableton"

if [[ ! -d "$prefs_dir" ]]; then
  printf 'ERROR: Ableton roaming preferences directory not found: %s\n' "$prefs_dir" >&2
  exit 1
fi

timestamp="$(date '+%Y%m%d-%H%M%S')"
backup_dir="${prefs_dir}.backup-${timestamp}"

if [[ -e "$backup_dir" ]]; then
  printf 'ERROR: backup path already exists: %s\n' "$backup_dir" >&2
  exit 1
fi

mv "$prefs_dir" "$backup_dir"
mkdir -p "$prefs_dir"

printf 'Backed up Ableton roaming preferences:\n'
printf '  from: %s\n' "$prefs_dir"
printf '  to:   %s\n' "$backup_dir"
printf 'Created fresh empty preferences directory: %s\n' "$prefs_dir"
