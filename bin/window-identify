#!/usr/bin/env bash
set -u

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/window-identify.log"
mkdir -p "$LOG_DIR"

exec > >(tee -a "$LOG_FILE") 2>&1

section() {
  printf '\n== %s ==\n' "$1"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

print_tool() {
  local tool="$1"

  if have_cmd "$tool"; then
    printf 'FOUND: %s -> %s\n' "$tool" "$(command -v "$tool")"
  else
    printf 'MISSING: %s\n' "$tool"
  fi
}

print_process_matches() {
  local label="$1"
  local pattern="$2"

  if pgrep -af "$pattern" >/dev/null 2>&1; then
    printf '%s: running\n' "$label"
    pgrep -af "$pattern" || true
  else
    printf '%s: not running\n' "$label"
  fi
}

printf '[%s] window identify start\n' "$(date '+%Y-%m-%d %H:%M:%S')"
printf 'WINEPREFIX=%s\n' "$WINEPREFIX"

if pgrep -af 'Ableton Live 12|Ableton Live 12 Suite\.exe|Ableton Live 12 Standard\.exe|Ableton Live 12 Intro\.exe' >/dev/null 2>&1; then
  printf 'PAUSED: Ableton window identification is disabled while native-window tests are paused.\n'
  printf 'Reason: live xprop/native-window testing can recreate the uncloseable Ableton window state.\n'
  printf 'Recovery: use ./bin/kill-session if Ableton is stuck.\n'
  printf '[%s] window identify end\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  exit 2
fi

section "Tool availability"
print_tool xprop
print_tool xwininfo
print_tool wmctrl
if have_cmd qdbus6; then
  printf 'FOUND: qdbus6 -> %s\n' "$(command -v qdbus6)"
elif have_cmd qdbus; then
  printf 'FOUND: qdbus -> %s\n' "$(command -v qdbus)"
else
  printf 'MISSING: qdbus/qdbus6\n'
fi

section "Process status"
print_process_matches "Ableton Live 12" 'Ableton Live 12|Ableton Live 12 Suite\.exe|Ableton Live 12 Standard\.exe|Ableton Live 12 Intro\.exe'
print_process_matches "Bome MIDI Translator Pro" 'Bome|MIDITranslator|MIDI Translator'
print_process_matches "Wine process list" '([w]ine|[W]ine|wineserver|winedevice|services\.exe|explorer\.exe|Ableton|MIDITranslator|Bome)'

section "Matching windows"
if have_cmd wmctrl; then
  if wmctrl -lx 2>/dev/null | grep -Ei 'Ableton|Live|Wine|Bome' >/dev/null 2>&1; then
    wmctrl -lx 2>/dev/null | grep -Ei 'Ableton|Live|Wine|Bome' || true
  else
    printf 'No wmctrl windows matched: Ableton, Live, Wine, Bome\n'
  fi
else
  printf 'wmctrl unavailable; cannot list matching windows\n'
fi

section "Manual xprop capture"
printf 'PAUSED: do not run xprop against Ableton while native-window tests are paused.\n'
printf 'Use only already-captured metadata or offline KDE Window Rules review.\n'

printf '\n[%s] window identify end\n' "$(date '+%Y-%m-%d %H:%M:%S')"
