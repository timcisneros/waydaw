#!/usr/bin/env bash
# End-state thread capture for a running Ableton session. Factored out of
# bin/ableton-auth-liveness-probe so the DXVK A/B harness and future
# diagnostics share one capture mechanism.
#
# Usage: ableton-thread-endstate-capture <output_dir> [label]
#
# Read-only: attaches winedbg (attach/bt/detach), samples /proc, reads window
# properties. Does not click, type, kill, or mutate anything. The caller owns
# session lifecycle.
set -uo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"
export DISPLAY="${DISPLAY:-:0}"

OUT="${1:-}"
LABEL="${2:-endstate}"
if [[ -z "$OUT" ]]; then
  echo "usage: $(basename "$0") <output_dir> [label]" >&2; exit 2
fi
mkdir -p "$OUT"
SUMMARY="$OUT/endstate.env"
kv() { printf '%s=%s\n' "$1" "${2:-}" | tee -a "$SUMMARY"; }

kv capture_label "$LABEL"
kv capture_time "$(date '+%Y-%m-%d %H:%M:%S')"

ABLETON_PID="$(pgrep -f 'Ableton Live 12 Suite\.exe' | head -1)"
kv ableton_unix_pid "${ABLETON_PID:-none}"
if [[ -z "$ABLETON_PID" ]]; then
  kv capture_result no_ableton_process
  exit 1
fi

# ---- window / process evidence
ps -eo pid,ppid,stat,etime,args | grep -Ei 'ableton|wine|msedge' | grep -v grep \
  >"$OUT/process-snapshot.txt" 2>&1 || true
kv webview2_process_count "$(grep -ci 'msedgewebview2\.exe' "$OUT/process-snapshot.txt" || true)"
wmctrl -lpG -x >"$OUT/wmctrl-lpGx.txt" 2>&1 || true

DIALOG_ID=""
PARENT_ID=""
while IFS= read -r line; do
  id="$(awk '{print $1}' <<<"$line")"
  wtype="$(xprop -id "$id" _NET_WM_WINDOW_TYPE 2>/dev/null)"
  [[ "$wtype" == *DIALOG* ]] || continue
  tf="$(xprop -id "$id" WM_TRANSIENT_FOR 2>/dev/null | awk '{print $NF}')"
  [[ "$tf" =~ ^0x[0-9a-fA-F]+$ ]] || continue
  DIALOG_ID="$id"; PARENT_ID="$tf"; break
done < <(wmctrl -lx 2>/dev/null | grep -i 'ableton live 12 suite\.exe' || true)
kv dialog_window_id "${DIALOG_ID:-none}"
kv parent_window_id "${PARENT_ID:-none}"

# ---- unix thread activity (2 samples, 3s apart)
sample_threads() {
  local out="$1"
  for tdir in /proc/"$ABLETON_PID"/task/*/; do
    tid="$(basename "$tdir")"
    stat_line="$(cat "$tdir/stat" 2>/dev/null)" || continue
    name="$(awk -F'[()]' '{print $2}' <<<"$stat_line")"
    state="$(awk -F') ' '{split($2,a," "); print a[1]}' <<<"$stat_line")"
    cpu="$(awk -F') ' '{split($2,a," "); print a[12]+a[13]}' <<<"$stat_line")"
    printf '%s|%s|%s|%s\n' "$tid" "$name" "$state" "$cpu"
  done >"$out"
}
sample_threads "$OUT/threads-sample-1.txt"
sleep 3
sample_threads "$OUT/threads-sample-2.txt"
kv thread_count "$(wc -l <"$OUT/threads-sample-2.txt")"
main1="$(grep "^$ABLETON_PID|" "$OUT/threads-sample-1.txt" | awk -F'|' '{print $4}')"
main2="$(grep "^$ABLETON_PID|" "$OUT/threads-sample-2.txt" | awk -F'|' '{print $4}')"
kv main_thread_state "$(grep "^$ABLETON_PID|" "$OUT/threads-sample-2.txt" | awk -F'|' '{print $3}')"
kv main_thread_cpu_ticks_per_3s "$(( ${main2:-0} - ${main1:-0} ))"
kv main_thread_total_cpu_ticks "${main2:-unknown}"

# ---- winedbg full backtraces
timeout 90 env -u WAYLAND_DISPLAY WINEPREFIX="$WINEPREFIX" \
  winedbg --command "info process" >"$OUT/winedbg-process-list.txt" 2>&1
WINPID="$(grep -i 'ableton live 12 suite\.exe' "$OUT/winedbg-process-list.txt" \
  | awk '{gsub(/^0+/,"",$1); print $1; exit}')"
kv ableton_win_pid "${WINPID:-not_found}"
if [[ -z "$WINPID" ]]; then
  kv capture_result no_winedbg_pid
  exit 1
fi
printf 'attach 0x%s\ninfo threads\nbt all\ndetach\nquit\n' "$WINPID" >"$OUT/winedbg-commands.txt"
timeout 300 env -u WAYLAND_DISPLAY WINEPREFIX="$WINEPREFIX" \
  winedbg <"$OUT/winedbg-commands.txt" >"$OUT/winedbg-btall.txt" 2>&1
kv winedbg_btall_exit_code "$?"

BT="$OUT/winedbg-btall.txt"
# First backtraced thread is the process's initial (main/UI) thread.
MAIN_TID="$(awk '/^Backtracing for thread/{print $4; exit}' "$BT")"
kv main_win_tid "${MAIN_TID:-unknown}"
awk -v t="thread ${MAIN_TID:-none}" \
  '$0 ~ "^Backtracing for "t" "{p=1} p&&/^Backtracing/&&$0 !~ t{exit} p' "$BT" \
  >"$OUT/main-thread-bt.txt"
kv main_thread_top_frames "$(grep -E '^=>0|^ +[1-3] 0x' "$OUT/main-thread-bt.txt" \
  | sed -E 's/\[[^]]*\]//g; s/\(.*\)//g; s/^[= >]*[0-9]+ 0x[0-9a-f]+ ?//' \
  | tr -s ' ' | tr '\n' ';' | head -c 300)"

kv threads_in_sendmessage "$(awk '/^Backtracing for thread/{t=$4} /SendMessageW|SendMessageTimeout/{print t}' "$BT" | sort -u | tr '\n' ',' )"
kv threads_in_srw_exclusive "$(awk '/^Backtracing for thread/{t=$4} /RtlAcquireSRWLockExclusive/{print t}' "$BT" | sort -u | tr '\n' ',')"
kv main_thread_in_srw_exclusive "$(grep -q 'RtlAcquireSRWLockExclusive' "$OUT/main-thread-bt.txt" && echo yes || echo no)"
kv main_thread_in_message_wait "$(grep -qE 'MsgWait|NtUserGetMessage|GetMessage|PeekMessage' "$OUT/main-thread-bt.txt" && echo yes || echo no)"
kv main_thread_in_d3d11 "$(grep -q 'in d3d11' "$OUT/main-thread-bt.txt" && echo yes || echo no)"

# ---- SRW lock word, when the main thread is waiting on one
LOCK_ADDR="$(grep -oE 'RtlAcquireSRWLockExclusive\+[^(]*\(lock=0*([0-9A-Fa-f]+)' "$OUT/main-thread-bt.txt" \
  | head -1 | sed -E 's/.*lock=0*/0x/')"
kv srw_lock_addr "${LOCK_ADDR:-none}"
if [[ -n "$LOCK_ADDR" ]]; then
  printf 'attach 0x%s\nx/2w %s\ndetach\nquit\n' "$WINPID" "${LOCK_ADDR,,}" >"$OUT/winedbg-lockword-commands.txt"
  timeout 120 env -u WAYLAND_DISPLAY WINEPREFIX="$WINEPREFIX" \
    winedbg <"$OUT/winedbg-lockword-commands.txt" >"$OUT/winedbg-lockword.txt" 2>&1
  kv srw_lock_word "$(grep -oE '0x[0-9a-f]+:  [0-9a-f]+ [0-9a-f]+' "$OUT/winedbg-lockword.txt" | head -1 | awk '{print $2" "$3}')"
fi

kv ableton_alive_after_capture "$([[ -d /proc/$ABLETON_PID ]] && echo yes || echo no)"
kv capture_result completed
