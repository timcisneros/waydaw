#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../config/env
source "$ROOT_DIR/config/env"

LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/ableton-contained.log"
mkdir -p "$LOG_DIR"

{
  printf '[%s] refused Ableton virtual desktop launch\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  printf 'WINEPREFIX=%s\n' "$WINEPREFIX"
  printf 'ERROR: Ableton Wine virtual desktop launch is disabled in Waydaw.\n'
  printf 'ERROR: Use ./bin/ableton or ./bin/session; those paths force XWayland and disable Wine desktop mode.\n'
} | tee -a "$LOG_FILE" >&2

exit 1
