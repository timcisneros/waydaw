#!/usr/bin/env bash

unset PYTHONHOME
unset PYTHONPATH
unset PYTHONSTARTUP
unset PYTHONUSERBASE
unset PYTHONEXECUTABLE
unset PYTHON
unset VIRTUAL_ENV
unset CONDA_PREFIX
unset CONDA_DEFAULT_ENV
unset CONDA_PYTHON_EXE
unset GDK_BACKEND
unset QT_QPA_PLATFORM
unset SDL_VIDEODRIVER

export WINEPREFIX="$HOME/WinePrefixes/ableton12"

# Optional opt-in runner selection (default: system Wine, no-op). Set
# WAYDAW_ABLETON_RUNNER=proton-exp for the experimental Proton-exp path.
source "$(dirname "${BASH_SOURCE[0]}")/ableton-runner.sh"
