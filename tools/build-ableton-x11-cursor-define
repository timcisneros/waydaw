#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT_DIR/tools/ableton-x11-cursor-define.c"
OUT="$ROOT_DIR/tools/ableton-x11-cursor-define"

fail() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

rm -f "$OUT"

command -v cc >/dev/null 2>&1 || fail "C compiler 'cc' not found"

if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists x11; then
  cc -O2 -Wall -Wextra "$SRC" -o "$OUT" $(pkg-config --cflags --libs x11)
else
  if ! printf '#include <X11/Xlib.h>\nint main(void){return 0;}\n' | cc -x c - -o /tmp/waydaw-x11-header-check -lX11 >/dev/null 2>&1; then
    rm -f /tmp/waydaw-x11-header-check
    fail "X11 development headers/libs missing (need X11/Xlib.h and libX11; on Fedora this is typically libX11-devel). Not installing without approval."
  fi
  rm -f /tmp/waydaw-x11-header-check
  cc -O2 -Wall -Wextra "$SRC" -o "$OUT" -lX11
fi

[[ -x "$OUT" ]] || fail "compile finished but output is not executable: $OUT"
printf 'built=%s\n' "$OUT"
